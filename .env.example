# ==============================================
# ASSOCAF Voice Agent - Variabili d'ambiente
# ==============================================
# Copia questo file in ".env" e compila i valori.

# --- Server ---
# Porta del server (Railway la imposta automaticamente, in locale usa 8080)
PORT=8080

# URL pubblico del server (senza slash finale), es. https://assocaf-voice-agent.up.railway.app
# Serve per generare il WebSocket URL nel TwiML. Su Railway usa il dominio generato.
PUBLIC_URL=https://il-tuo-dominio.up.railway.app

# --- Deepgram (OBBLIGATORIO) ---
# API key Deepgram (Console > API Keys). Serve per STT + TTS + Voice Agent.
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modello STT (trascrizione). Consigliato: nova-2 (supporta italiano)
DEEPGRAM_STT_MODEL=nova-2

# Voce TTS Aura-2 in italiano. Es: aura-2-nestor-it (maschile), aura-2-aurora-it (femminile)
DEEPGRAM_TTS_VOICE=aura-2-nestor-it

# --- LLM / Cervello AI ---
# Endpoint compatibile OpenAI per il modello linguistico.
# Puoi usare il tuo endpoint Abacus (stesso del sito) oppure OpenAI.
LLM_ENDPOINT_URL=https://apps.abacus.ai/v1/chat/completions
LLM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=gpt-4o-mini

# --- Twilio (per la verifica firma dei webhook, opzionale ma consigliato) ---
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Abilita/disabilita la verifica della firma Twilio (true in produzione)
VERIFY_TWILIO_SIGNATURE=false
